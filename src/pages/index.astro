---
import Base from '../layouts/Base.astro';
import {
  person,
  links,
  now,
  work,
  publications,
  experience,
  authorsHtml,
  venueLine,
} from '../data/site.js';

const selected = publications.filter((p) => p.status === 'published');
---

<Base path="/">
  <header class="lead">
    <div class="lead__text">
      <h1>{person.name}</h1>
      <p class="tagline">{person.tagline}</p>
      <ul class="linkrow lead__links">
        {
          links.map((l) => (
            <li>
              <a href={l.href}>{l.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
    <figure class="lead__figure">
      <img
        src={person.photo.src}
        alt={person.photo.alt}
        width="1400"
        height="1050"
        loading="eager"
        decoding="async"
      />
      <figcaption>{person.photo.caption}</figcaption>
    </figure>
  </header>

  <section>
    <h2 class="section-label">Now</h2>
    <ul class="entries">
      {
        now.map((n) => (
          <li class="entry dated">
            <span class="dated__when">{n.date}</span>
            <p class="entry__body" set:html={n.body} />
          </li>
        ))
      }
    </ul>
  </section>

  <section>
    <h2 class="section-label">Selected work</h2>
    <ul class="entries">
      {
        work.map((w) => (
          <li class="entry">
            <h3 class="entry__title">{w.title}</h3>
            <p class="entry__body">{w.what}</p>
            <p class="entry__meta">
              {w.stack}
              {w.linkset.length > 0 && ' — '}
              {w.linkset.map((l, i) => (
                <>
                  {i > 0 && ' · '}
                  <a href={l.href}>{l.label}</a>
                </>
              ))}
              {w.note && <span class="entry__note">{w.note}</span>}
            </p>
          </li>
        ))
      }
    </ul>
  </section>

  <section>
    <h2 class="section-label">Publications</h2>
    <ul class="entries">
      {
        selected.map((p) => (
          <li class="pub">
            <p class="pub__title">{p.title}</p>
            <p class="pub__authors" set:html={authorsHtml(p.authors)} />
            <p class="pub__venue">{venueLine(p, { full: false })}</p>
            <p class="entry__meta">
              {p.linkset.map((l, i) => (
                <>
                  {i > 0 && ' · '}
                  <a href={l.href}>{l.label}</a>
                </>
              ))}
            </p>
          </li>
        ))
      }
    </ul>
    <p class="entry__meta" style="margin-top:1.1rem">
      <a href="/publication/">All publications</a> · <a
        href={`https://orcid.org/${person.orcid}`}>ORCID</a
      >
    </p>
  </section>

  <section>
    <h2 class="section-label">Experience</h2>
    <ul class="entries">
      {
        experience.map((e) => (
          <li class="entry dated">
            <span class="dated__when">{e.when}</span>
            <div>
              <div class="entry__head">
                <div class="entry__lead">
                  <h3 class="entry__title">{e.role}</h3>
                  <p class="entry__org">{e.org}</p>
                </div>
                <span class="entry__where">{e.where}</span>
              </div>
              <p class="entry__body" set:html={e.note} />
            </div>
          </li>
        ))
      }
    </ul>
    <p class="entry__meta" style="margin-top:1.1rem">
      <a href="/research/">Research</a> · <a href="/curriculum-vitae/">Full CV</a> ·
      <a href="/beyond/">Beyond research</a>
    </p>
  </section>
</Base>
